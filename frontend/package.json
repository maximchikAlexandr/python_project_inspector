{
  "name": "ppi-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "i18n:extract": "node ./scripts/i18next-cli.mjs extract",
    "openapi:generate": "openapi-typescript ../openapi.json -o src/api/openapi-generated.d.ts",
    "openapi:dump": "uv run --project .. ppi --repo . openapi --output ../openapi.json",
    "preview": "vite preview",
    "build:webview": "vite build --config vite.webview.config.ts",
    "test:unit": "vitest run",
    "test": "vitest run"
  },
  "dependencies": {
    "@mantine/charts": "^7.17.8",
    "@mantine/core": "^7.17.8",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "remeda": "^2.39.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "i18next-cli": "^1.64.1",
    "knip": "^6.23.0",
    "openapi-typescript": "^7.13.0",
    "ts-expect": "^1.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.9"
  }
}
